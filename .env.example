API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-5.4-mini
OPENAI_API_KEY=your_api_key_here

# Optional alternative auth used by inference.py and the loader
# HF_TOKEN=
# API_KEY=

# Path to a directory containing repo_rules.json, tasks.json, and issues.json
DATA_DIR=data
# TRIAGE_DATA_DIR=data

# Optional server-side overrides
# STRICT_MODE=true
# REPO_RULES_SOURCE=
# TASKS_SOURCE=
# ISSUES_SOURCE=

# Runner tuning
MAX_STEPS=8
TEMPERATURE=0.2
MAX_OUTPUT_TOKENS=180

# Optional machine-readable output from inference.py
# INFERENCE_RESULTS_PATH=results.json
